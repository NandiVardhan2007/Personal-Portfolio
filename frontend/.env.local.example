# Copy this file to .env.local and fill in your real values there.
# .env.local is gitignored — never commit real secrets.

# Optional — raises the GitHub stats rate limit from 60/hr to 5,000/hr.
# Create one at https://github.com/settings/tokens (read:user scope is enough).
GITHUB_TOKEN=

# Only needed if you move the coding-stats backend to a different URL.
CODING_STATS_API_URL=https://personal-portfolio-u9e1.onrender.com

# Chatbot backend — defaults to https://personal-portfolio-u9e1.onrender.com (same backend as
# coding stats). Only override if it moves. No API key needed here — that backend
# holds its own NVIDIA NIM key server-side.
NIM_API_URL=https://personal-portfolio-u9e1.onrender.com

# Contact form backend — defaults to https://personal-portfolio-u9e1.onrender.com (same
# backend as coding stats / chatbot). It handles AI auto-reply generation,
# Brevo email delivery, and notifying you — no keys needed on our side.
CONTACT_API_URL=https://personal-portfolio-u9e1.onrender.com

# Used for sitemap.xml, robots.txt, and Open Graph/Twitter meta tags. Set this
# to your real deployed URL once you have one (defaults to a placeholder).
NEXT_PUBLIC_SITE_URL=
