# Environment variables for the backend scraper
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git — it is already in .gitignore.

# ── Usernames ────────────────────────────────────────────────────────────────
LEETCODE_USERNAME=Nandu_2007_
CODECHEF_USERNAME=nandu_2007
HACKERRANK_USERNAME=24p31a1224
GFG_USERNAME=24p31ap7i2

# ── CodeChef credentials (for authenticated scraping) ────────────────────────
# These allow fetching your full rating, stars, and rank.
# Set these in your deployment platform's secret/environment settings.
CODECHEF_PASSWORD=your_password_here

# ── NVIDIA NIM AI Chatbot ────────────────────────────────────────────────────
# Get your key from https://build.nvidia.com
NIM_API_KEY=nvapi-your_key_here

# ── Brevo (Sendinblue) Transactional Email ───────────────────────────────────
# Get your API key from https://app.brevo.com → Settings → SMTP & API
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=Your Name
BREVO_NOTIFY_EMAIL=your_inbox@example.com
